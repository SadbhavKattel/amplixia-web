# Public site URL — used in metadata, sitemap, OG, canonical links.
NEXT_PUBLIC_SITE_URL="https://amplixia.com"

# Database (Postgres). For local dev you can use a Neon/Supabase free tier.
DATABASE_URL="postgresql://user:password@host:5432/amplixia"

# Resend transactional email — https://resend.com
RESEND_API_KEY=""
LEAD_NOTIFICATION_FROM="Amplixia <leads@notify.amplixia.com>"
LEAD_NOTIFICATION_TO="services@amplixia.com"

# Upstash Redis (rate limiting). https://upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Cloudflare Turnstile (bot protection). https://www.cloudflare.com/products/turnstile/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
