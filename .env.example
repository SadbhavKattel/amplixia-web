# Public site URL — used in metadata, sitemap, OG, canonical links.
NEXT_PUBLIC_SITE_URL="https://amplixia.com"

# Database (Postgres).
# DATABASE_URL should be the runtime connection string.
# For Supabase production/serverless, prefer pooled connection (port 6543 + pgbouncer=true).
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Optional but recommended with Prisma when using pooled DATABASE_URL.
# Use a direct connection (typically port 5432) for migrations and db push.
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/postgres?sslmode=require"

# Resend transactional email — https://resend.com
RESEND_API_KEY=""
LEAD_NOTIFICATION_FROM="Amplixia <leads@notify.amplixia.com>"
LEAD_NOTIFICATION_TO="services@amplixia.com"

# Upstash Redis (rate limiting). https://upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Cloudflare Turnstile (bot protection). https://www.cloudflare.com/products/turnstile/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
